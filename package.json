{
  "name": "doc-codesome",
  "version": "1.0.0",
  "private": true,
  "description": "Codesome 平台使用文档站（Docsify）",
  "scripts": {
    "dev": "docsify serve . --port 3008",
    "sync:cdc": "node scripts/sync-cdc.mjs",
    "check:cdc": "node scripts/sync-cdc.mjs --check",
    "check:links": "node scripts/check-links.mjs",
    "check:images": "node scripts/check-images.mjs",
    "check": "npm run check:cdc && npm run check:links && npm run check:images"
  },
  "devDependencies": {
    "docsify-cli": "^4.4.4"
  }
}
